# URL base de tu backend Express. Si tu backend corre en otro puerto, cámbialo aquí.
# (Debe empezar con VITE_ para que Vite lo exponga al frontend)
VITE_API_URL=http://localhost:3000/api

# Credenciales públicas de Supabase (la "anon key" está pensada para el cliente).
# Se usan solo para leer catálogos públicos como la lista de roles del registro.
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key
